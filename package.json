{
  "name": "loop-skills",
  "version": "0.5.3",
  "description": "Research-driven planning, debugging, and audit skills for Pi, Claude Code, and other agents",
  "type": "module",
  "bin": {
    "loop-skills": "dist/src/install.js",
    "claude-skills": "dist/src/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/src/install.js",
    "extensions/loop-progress.ts",
    "extensions/loop-inventory.ts",
    "extensions/loop-evidence.ts",
    "extensions/loop-limits.ts",
    "skills/",
    "agents/",
    "bin/",
    "commands/",
    "templates/",
    "checksums.txt"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "check:extensions": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --skipLibCheck extensions/*.ts",
    "test": "node --test dist/test/installer.test.js dist/test/pi-package.test.js && npm run check:extensions",
    "test:e2e": "bash test/e2e-published.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tech1ee/loop-skills.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "pi-package",
    "pi-coding-agent",
    "ai-agent",
    "loop-plan",
    "loop-debug",
    "planning",
    "tdd"
  ],
  "pi": {
    "skills": [
      "./skills/pi"
    ],
    "extensions": [
      "./extensions/loop-progress.ts",
      "./extensions/loop-inventory.ts",
      "./extensions/loop-evidence.ts",
      "./extensions/loop-limits.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "license": "MIT",
  "author": "Arman Aralbayev <t3ch1ee@gmail.com>"
}
